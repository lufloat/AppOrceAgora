{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish OrceAgora.API/OrceAgora.API.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "dotnet out/OrceAgora.API.dll",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}